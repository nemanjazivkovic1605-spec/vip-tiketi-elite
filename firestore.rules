rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'nemanjazivkovic1605@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) && (
        isAdmin() ||
        (
          incoming().uid == userId &&
          incoming().role == 'user' &&
          incoming().isAdmin == false &&
          incoming().status == 'active' &&
          incoming().vipAccess == false &&
          incoming().vipExpiresAt == null &&
          incoming().vip_expires_at == null &&
          incoming().membershipStatus in ['free', 'pending']
        )
      );
      allow update: if isAdmin() || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'uid',
          'email',
          'role',
          'isAdmin',
          'status',
          'accountStatus',
          'membershipStatus',
          'vipAccess',
          'vipExpiresAt',
          'vip_expires_at',
          'selectedPlan',
          'plan',
          'planName',
          'planDurationDays',
          'approvedAt',
          'approvedBy',
          'adminNote'
        ])
      );
      allow delete: if isAdmin();
    }

    // Admin notifications
    match /adminNotifications/{notificationId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn() &&
        incoming().type == 'new_user_registration' &&
        incoming().userEmail == request.auth.token.email &&
        incoming().read == false;
    }

    // Packages
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Stats
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins collection (optional but good practice)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
