rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasAdminRole() {
      return isSignedIn() &&
        exists(userPath(request.auth.uid)) &&
        get(userPath(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'nemanjazivkovic1605@gmail.com' ||
        hasAdminRole()
      );
    }

    function hasVerifiedEmail() {
      return isAdmin() || (
        isSignedIn() && (
          request.auth.token.email_verified == true ||
          (
            exists(userPath(request.auth.uid)) &&
            get(userPath(request.auth.uid)).data.emailVerified == true
          )
        )
      );
    }

    function currentUser() {
      return get(userPath(request.auth.uid)).data;
    }

    function hasVipAccess() {
      return isAdmin() || (
        (
          hasVerifiedEmail() &&
          currentUser().role == 'admin'
        ) ||
        (
          hasVerifiedEmail() &&
          currentUser().vipApproved == true &&
          currentUser().vipAccess == true &&
          currentUser().membershipStatus == 'approved' &&
          currentUser().status == 'active' &&
          currentUser().vipExpiresAt > request.time
        )
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isAdmin() || hasVipAccess() || (
        hasVerifiedEmail() &&
        resource.data.publicationStatus == 'PUBLISHED' &&
        resource.data.isVip == false
      );
      allow write: if isAdmin();
    }

    // Public ticket index. VIP predictions and analysis must never be stored here.
    match /publicTickets/{ticketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public statistics source contains only settled published tickets.
    match /publicStatsTickets/{ticketId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        incoming().publicationStatus == 'PUBLISHED' &&
        incoming().status in ['WON', 'LOST', 'REFUND'] &&
        incoming().locked == false &&
        incoming().analysis == '';
      allow delete: if isAdmin();
    }

    // Optional precomputed public aggregates. These collections contain no
    // private ticket payloads and remain readable without authentication.
    match /publicStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /publicMonthlyStats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Full daily analysis data is limited to VIP/admin clients.
    match /dailyAnalyses/{analysisId} {
      allow read: if isAdmin() || hasVipAccess();
      allow write: if isAdmin();
    }

    // Locked VIP summaries contain no prediction, odds or analysis.
    match /publicDailyAnalyses/{analysisId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        incoming().keys().hasOnly(['id', 'sport', 'league', 'date', 'time', 'type', 'status', 'locked']) &&
        incoming().id == analysisId &&
        incoming().type == 'VIP' &&
        incoming().locked == true;
      allow delete: if isAdmin();
    }

    // Full FREE daily analyses are available after email verification.
    match /freeDailyAnalyses/{analysisId} {
      allow read: if hasVerifiedEmail();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) && (
        isAdmin() ||
        (
          incoming().uid == userId &&
          incoming().role == 'user' &&
          incoming().isAdmin == false &&
          incoming().emailVerified == false &&
            incoming().status == 'active' &&
            incoming().vipAccess == false &&
            incoming().vipApproved == false &&
            incoming().vipStatus == 'inactive' &&
            incoming().approved == false &&
            incoming().vipExpiresAt == null &&
            incoming().vip_expires_at == null &&
            incoming().membershipStatus == 'free' &&
            incoming().plan == 'free' &&
            incoming().selectedPlan == 'free'
        )
      );
      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emailVerified', 'verified', 'updatedAt']) &&
        incoming().emailVerified == request.auth.token.email_verified &&
        (!request.resource.data.keys().hasAny(['verified']) || incoming().verified == request.auth.token.email_verified)
      ) || (
        isOwner(userId) &&
        (request.auth.token.email_verified == true || existing().emailVerified == true) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'emailVerified',
          'verified',
          'status',
          'accountStatus',
          'membershipStatus',
          'plan',
          'planName',
          'planDurationDays',
          'vipAccess',
          'vipApproved',
          'vipStatus',
          'approved',
          'vipExpiresAt',
          'vip_expires_at',
          'updatedAt'
        ]) &&
        incoming().emailVerified == true &&
        incoming().verified == true &&
        incoming().status == 'active' &&
        incoming().accountStatus == 'active' &&
        incoming().membershipStatus == 'free' &&
        incoming().plan == 'free' &&
        incoming().vipAccess == false &&
        incoming().vipApproved == false &&
        incoming().vipStatus == 'inactive' &&
        incoming().approved == false &&
        incoming().vipExpiresAt == null &&
        incoming().vip_expires_at == null
      ) || (
        isOwner(userId) &&
        hasVerifiedEmail() &&
        existing().role == 'user' &&
        existing().status == 'active' &&
        existing().vipAccess == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'selectedPlan',
          'planName',
          'planDurationDays',
          'membershipStatus',
          'plan',
          'vipAccess',
          'vipApproved',
          'vipStatus',
          'approved',
          'vipExpiresAt',
          'vip_expires_at',
          'updatedAt'
        ]) &&
        incoming().selectedPlan in ['silver_7', 'gold_30', 'elite_90'] &&
        incoming().membershipStatus == 'pending' &&
        incoming().plan == 'free' &&
        incoming().vipAccess == false &&
        incoming().vipApproved == false &&
        incoming().vipStatus == 'pending' &&
        incoming().approved == false &&
        incoming().vipExpiresAt == null &&
        incoming().vip_expires_at == null
      ) || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'uid',
          'email',
          'emailVerified',
          'role',
          'isAdmin',
          'status',
          'accountStatus',
          'membershipStatus',
          'vipAccess',
          'vipApproved',
          'vipStatus',
          'approved',
          'vipExpiresAt',
          'vip_expires_at',
          'selectedPlan',
          'plan',
          'planName',
          'planDurationDays',
          'approvedAt',
          'approvedBy',
          'adminNote'
        ])
      );
      allow delete: if isAdmin();
    }

    // Admin notifications
    match /adminNotifications/{notificationId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn() &&
        incoming().userEmail == request.auth.token.email &&
        incoming().read == false &&
        (
          incoming().type == 'new_user_registration' ||
          (
            incoming().type == 'vip_plan_request' &&
            hasVerifiedEmail() &&
            incoming().selectedPlan in ['silver_7', 'gold_30', 'elite_90']
          )
        );
    }

    // Packages
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Stats
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User reviews. Public visitors can only read approved reviews.
    match /reviews/{reviewId} {
      allow read: if isAdmin() || resource.data.status == 'approved';
      allow create: if isSignedIn() &&
        incoming().userId == request.auth.uid &&
        incoming().status == 'pending' &&
        incoming().rating is number &&
        incoming().rating >= 1 &&
        incoming().rating <= 5 &&
        incoming().name is string &&
        incoming().name.size() >= 2 &&
        incoming().name.size() <= 80 &&
        incoming().text is string &&
        incoming().text.size() >= 5 &&
        incoming().text.size() <= 600;
      allow update, delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins collection (optional but good practice)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
