# Server-only Gemini key used by /api/generate-daily-analysis.
# Configure this in Vercel Environment Variables; never rename it to VITE_GEMINI_API_KEY.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Resend email service.
# The backend route uses this key to send verification, reset, welcome, and contact emails.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_CONTACT_TO_EMAIL="nemanjazivkovic1605@gmail.com"
RESEND_TEMPLATE_WELCOME_ID=""
RESEND_TEMPLATE_CONTACT_ID=""

# Firebase Admin service account required for custom verification and password reset links.
FIREBASE_SERVICE_ACCOUNT_KEY="{\"type\":\"service_account\",...}"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_APP_URL="https://eliteviptips.com"

# API-Football / api-sports.io v3 API key. Used only in the browser through Vite env.
VITE_FOOTBALL_API_KEY="MOJ_API_KLJUC"

# API-Basketball / api-sports.io API key. Can use the same API-Sports key.
VITE_BASKETBALL_API_KEY="MOJ_API_KLJUC"

# true = show only real football-data.org API data; false = allow local mock fallback.
VITE_USE_REAL_API=false

# EmailJS contact form. Create these in EmailJS dashboard.
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="public_key_xxxxxxx"
VITE_EMAILJS_WELCOME_TEMPLATE_ID="template_welcome_xxxxxxx"

# Public footer/contact email stays support@eliteviptips.com, while submitted messages are sent to Gmail.
VITE_CONTACT_DISPLAY_EMAIL="support@eliteviptips.com"
VITE_CONTACT_TO_EMAIL="nemanjazivkovic1605@gmail.com"

# Firebase web config. Production can use these Vercel env vars; if omitted,
# the app falls back to firebase-applet-config.json.
VITE_FIREBASE_API_KEY="AIza..."
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="1:xxxxx:web:xxxxx"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="xxxxx"
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIRESTORE_DATABASE_ID="(default)"
